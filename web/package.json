{
  "name": "@helpwave/tasks",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "build-intl": "npx build-intl -i locales -o ./i18n/translations.ts -n tasksTranslation -f",
    "build": "npm run build-intl & next build",
    "start": "next start",
    "lint": "tsc --noEmit && eslint .",
    "test": "vitest run",
    "generate-graphql": "graphql-codegen",
    "check-translations": "node scripts/check-translation-keys.mjs"
  },
  "browserslist": [
    "last 3 iOS versions",
    "last 3 Safari versions",
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "Firefox ESR"
  ],
  "overrides": {
    "postcss": "8.5.15"
  },
  "dependencies": {
    "@apollo/client": "4.2.3",
    "@dnd-kit/core": "6.3.1",
    "@dnd-kit/modifiers": "9.0.0",
    "@dnd-kit/sortable": "10.0.0",
    "@helpwave/hightide": "^0.12.4",
    "@helpwave/internationalization": "0.4.0",
    "@tailwindcss/postcss": "4.3.1",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-query-devtools": "5.101.0",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "^3.14.3",
    "@types/formidable": "3.5.1",
    "clsx": "2.1.1",
    "dotenv": "17.4.2",
    "formidable": "3.5.4",
    "graphql-ws": "6.0.8",
    "lucide-react": "1.20.0",
    "next": "^16.2.9",
    "oidc-client-ts": "3.5.0",
    "postcss": "8.5.15",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sharp": "0.35.1",
    "tailwindcss": "4.3.1",
    "typescript": "6.0.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "7.1.3",
    "@graphql-codegen/client-preset": "6.0.1",
    "@graphql-codegen/typescript": "6.0.2",
    "@graphql-codegen/typescript-operations": "6.0.4",
    "@graphql-codegen/typescript-react-query": "7.0.3",
    "@helpwave/eslint-config": "0.0.11",
    "@playwright/test": "1.61.0",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.0",
    "baseline-browser-mapping": "^2.9.19",
    "eslint": "9.39.1",
    "graphql": "16.12.0",
    "graphql-request": "7.4.0",
    "postcss-flexbugs-fixes": "5.0.2",
    "vitest": "^4.1.9"
  }
